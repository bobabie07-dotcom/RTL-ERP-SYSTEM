# ── Database ───────────────────────────────────────────────────────────────
# Local dev
ENVIRONMENT=development
DB_HOST=localhost
DB_PORT=3306
DB_NAME=poultry_erp
DB_USER=root
DB_PASSWORD=your_password

# Aiven (production) — overwrite the four values above with Aiven connection details
# DB_HOST=your-service.aivencloud.com
# DB_PORT=21699
# DB_NAME=defaultdb
# DB_USER=avnadmin
# DB_PASSWORD=your-aiven-password

# Paste the FULL contents of Aiven's ca.pem here (leave blank for local dev)
DB_SSL_CA=

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Keep enabled for legacy installs that still rely on app startup schema patches.
# Set to false after moving schema changes to a real migration runner such as Alembic.
RUN_STARTUP_MIGRATIONS=true
